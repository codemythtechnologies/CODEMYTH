# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real secrets.

# ---- Firebase client (safe to expose — identifies the project, not a secret) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server-only — service account, NEVER expose to the client) ----
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the full private key from the service-account JSON, keeping the
# \n escape sequences literally — the code un-escapes them at runtime.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Outgoing mail (contact + BA consult forms) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Code Myth Website <no-reply@yourdomain.com>"
CONTACT_INBOX=codemyth.technologies@gmail.com

# ---- Misc ----
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
